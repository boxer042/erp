generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// 인증 & 사용자
// ============================================================

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  name       String
  role       UserRole @default(STAFF)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdOrders    Order[]
  createdIncomings Incoming[]
  supplierPayments SupplierPayment[]

  @@map("users")
}

// ============================================================
// 판매 채널
// ============================================================

model SalesChannel {
  id             String   @id @default(uuid())
  name           String   @unique
  code           String   @unique
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 4)
  isActive       Boolean  @default(true) @map("is_active")
  memo           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  channelFees     ChannelFee[]
  channelPricings ChannelPricing[]
  orders          Order[]

  @@map("sales_channels")
}

model ChannelFee {
  id        String       @id @default(uuid())
  channelId String       @map("channel_id")
  channel   SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  feeType   FeeType      @map("fee_type")
  value     Decimal      @db.Decimal(12, 2)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("channel_fees")
}

enum FeeType {
  PERCENTAGE
  FIXED
}

// ============================================================
// 거래처 (공급자) 관리
// ============================================================

enum PaymentMethod {
  CREDIT
  PREPAID
}

model Supplier {
  id              String        @id @default(uuid())
  name            String
  businessNumber  String?       @map("business_number")
  representative  String?
  phone           String?
  email           String?
  address         String?
  paymentMethod   PaymentMethod @default(CREDIT) @map("payment_method")
  paymentTermDays Int           @default(30) @map("payment_term_days")
  memo            String?
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  supplierProducts SupplierProduct[]
  incomings        Incoming[]
  payments         SupplierPayment[]
  balanceLedger    SupplierLedger[]

  @@map("suppliers")
}

model SupplierLedger {
  id            String          @id @default(uuid())
  supplierId    String          @map("supplier_id")
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  date          DateTime        @default(now())
  type          LedgerEntryType
  description   String
  debitAmount   Decimal         @default(0) @map("debit_amount") @db.Decimal(15, 2)
  creditAmount  Decimal         @default(0) @map("credit_amount") @db.Decimal(15, 2)
  balance       Decimal         @map("balance") @db.Decimal(15, 2)
  referenceId   String?         @map("reference_id")
  referenceType String?         @map("reference_type")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([supplierId, date])
  @@map("supplier_ledgers")
}

enum LedgerEntryType {
  PURCHASE
  PAYMENT
  ADJUSTMENT
  REFUND
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String   @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @map("payment_date")
  method      String
  memo        String?
  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([supplierId, paymentDate])
  @@map("supplier_payments")
}

// ============================================================
// 상품 관리
// ============================================================

enum TaxType {
  TAXABLE
  TAX_FREE
  ZERO_RATE
}

model Product {
  id            String   @id @default(uuid())
  name          String
  sku           String   @unique
  barcode       String?  @unique
  description   String?
  unitOfMeasure String   @default("EA") @map("unit_of_measure")
  taxType       TaxType  @default(TAXABLE) @map("tax_type")
  taxRate       Decimal  @default(0.1) @map("tax_rate") @db.Decimal(5, 4)
  sellingPrice  Decimal  @default(0) @map("selling_price") @db.Decimal(15, 2)
  isSet         Boolean  @default(false) @map("is_set")
  isActive      Boolean  @default(true) @map("is_active")
  imageUrl      String?  @map("image_url")
  memo          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  setComponents   SetComponent[]   @relation("SetParent")
  partOfSets      SetComponent[]   @relation("SetChild")
  productMappings ProductMapping[]
  channelPricings ChannelPricing[]
  inventory       Inventory?
  orderItems      OrderItem[]
  sellingCosts    SellingCost[]

  @@map("products")
}

model SupplierProduct {
  id            String   @id @default(uuid())
  supplierId    String   @map("supplier_id")
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  name          String
  supplierCode  String?  @map("supplier_code")
  unitOfMeasure String   @default("EA") @map("unit_of_measure")
  unitPrice     Decimal  @default(0) @map("unit_price") @db.Decimal(15, 2)
  currency      String   @default("KRW")
  leadTimeDays  Int?     @map("lead_time_days")
  minOrderQty   Int      @default(1) @map("min_order_qty")
  isActive      Boolean  @default(true) @map("is_active")
  memo          String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  productMappings ProductMapping[]
  incomingItems   IncomingItem[]
  incomingCosts   IncomingCost[]

  @@unique([supplierId, supplierCode])
  @@map("supplier_products")
}

model ProductMapping {
  id                String          @id @default(uuid())
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  productId         String          @map("product_id")
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  conversionRate    Decimal         @default(1) @map("conversion_rate") @db.Decimal(10, 4)
  isDefault         Boolean         @default(false) @map("is_default")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@unique([supplierProductId, productId])
  @@map("product_mappings")
}

model SetComponent {
  id           String   @id @default(uuid())
  setProductId String   @map("set_product_id")
  setProduct   Product  @relation("SetParent", fields: [setProductId], references: [id], onDelete: Cascade)
  componentId  String   @map("component_id")
  component    Product  @relation("SetChild", fields: [componentId], references: [id], onDelete: Restrict)
  quantity     Decimal  @db.Decimal(10, 4)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([setProductId, componentId])
  @@map("set_components")
}

model ChannelPricing {
  id           String       @id @default(uuid())
  productId    String       @map("product_id")
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelId    String       @map("channel_id")
  channel      SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sellingPrice Decimal      @map("selling_price") @db.Decimal(15, 2)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([productId, channelId])
  @@map("channel_pricings")
}

// ============================================================
// 비용 관리
// ============================================================

model IncomingCost {
  id                String          @id @default(uuid())
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  name              String
  costType          FeeType         @map("cost_type")
  value             Decimal         @db.Decimal(12, 2)
  perUnit           Boolean         @default(true) @map("per_unit")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@map("incoming_costs")
}

model SellingCost {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  costType  FeeType  @map("cost_type")
  value     Decimal  @db.Decimal(12, 2)
  perUnit   Boolean  @default(true) @map("per_unit")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("selling_costs")
}

// ============================================================
// 재고 관리
// ============================================================

model Inventory {
  id          String   @id @default(uuid())
  productId   String   @unique @map("product_id")
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Decimal  @default(0) @db.Decimal(15, 4)
  safetyStock Decimal  @default(0) @map("safety_stock") @db.Decimal(15, 4)
  updatedAt   DateTime @updatedAt @map("updated_at")

  movements InventoryMovement[]

  @@map("inventories")
}

enum MovementType {
  INCOMING
  OUTGOING
  ADJUSTMENT_PLUS
  ADJUSTMENT_MINUS
  SET_CONSUME
  SET_PRODUCE
  RETURN
}

model InventoryMovement {
  id            String       @id @default(uuid())
  inventoryId   String       @map("inventory_id")
  inventory     Inventory    @relation(fields: [inventoryId], references: [id])
  type          MovementType
  quantity      Decimal      @db.Decimal(15, 4)
  balanceAfter  Decimal      @map("balance_after") @db.Decimal(15, 4)
  referenceId   String?      @map("reference_id")
  referenceType String?      @map("reference_type")
  memo          String?
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([inventoryId, createdAt])
  @@map("inventory_movements")
}

// ============================================================
// 입고 관리
// ============================================================

enum IncomingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Incoming {
  id           String         @id @default(uuid())
  incomingNo   String         @unique @map("incoming_no")
  supplierId   String         @map("supplier_id")
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  status       IncomingStatus @default(PENDING)
  incomingDate DateTime       @map("incoming_date")
  totalAmount  Decimal        @default(0) @map("total_amount") @db.Decimal(15, 2)
  taxAmount    Decimal        @default(0) @map("tax_amount") @db.Decimal(15, 2)
  memo         String?
  createdById  String         @map("created_by_id")
  createdBy    User           @relation(fields: [createdById], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  items IncomingItem[]

  @@index([supplierId, incomingDate])
  @@map("incomings")
}

model IncomingItem {
  id                String          @id @default(uuid())
  incomingId        String          @map("incoming_id")
  incoming          Incoming        @relation(fields: [incomingId], references: [id], onDelete: Cascade)
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id])
  quantity          Decimal         @db.Decimal(15, 4)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(15, 2)
  totalPrice        Decimal         @map("total_price") @db.Decimal(15, 2)
  memo              String?

  @@map("incoming_items")
}

// ============================================================
// 주문 관리
// ============================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Order {
  id               String       @id @default(uuid())
  orderNo          String       @unique @map("order_no")
  channelId        String       @map("channel_id")
  channel          SalesChannel @relation(fields: [channelId], references: [id])
  channelOrderNo   String?      @map("channel_order_no")
  status           OrderStatus  @default(PENDING)
  customerName     String?      @map("customer_name")
  customerPhone    String?      @map("customer_phone")
  shippingAddress  String?      @map("shipping_address")
  orderDate        DateTime     @map("order_date")
  subtotalAmount   Decimal      @default(0) @map("subtotal_amount") @db.Decimal(15, 2)
  discountAmount   Decimal      @default(0) @map("discount_amount") @db.Decimal(15, 2)
  shippingFee      Decimal      @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  taxAmount        Decimal      @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount      Decimal      @default(0) @map("total_amount") @db.Decimal(15, 2)
  commissionAmount Decimal      @default(0) @map("commission_amount") @db.Decimal(15, 2)
  memo             String?
  createdById      String       @map("created_by_id")
  createdBy        User         @relation(fields: [createdById], references: [id])
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  items OrderItem[]

  @@index([channelId, orderDate])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String  @map("product_id")
  product    Product @relation(fields: [productId], references: [id])
  quantity   Decimal @db.Decimal(15, 4)
  unitPrice  Decimal @map("unit_price") @db.Decimal(15, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(15, 2)
  memo       String?

  @@map("order_items")
}
