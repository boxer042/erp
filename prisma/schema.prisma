generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 인증 & 사용자
// ============================================================

enum UserRole {
  ADMIN
  STAFF
}

model User {
  id         String   @id @default(uuid())
  supabaseId String   @unique @map("supabase_id")
  email      String   @unique
  name       String
  role       UserRole @default(STAFF)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdOrders     Order[]
  createdIncomings  Incoming[]
  supplierPayments  SupplierPayment[]
  customerPayments  CustomerPayment[]
  supplierReturns   SupplierReturn[]
  createdQuotations Quotation[]
  createdStatements Statement[]
  customerNotes     CustomerNote[]
  createdRepairs    RepairTicket[]
  createdRentals    Rental[]
  createdExpenses   Expense[]

  @@map("users")
}

// ============================================================
// 판매 채널
// ============================================================

model SalesChannel {
  id             String   @id @default(uuid())
  name           String   @unique
  code           String   @unique
  commissionRate Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 4)
  isActive       Boolean  @default(true) @map("is_active")
  memo           String?
  logoUrl        String?  @map("logo_url")
  logoPath       String?  @map("logo_path")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  channelFees              ChannelFee[]
  channelPricings          ChannelPricing[]
  orders                   Order[]
  sellingCosts             SellingCost[]
  channelCategoryMappings  ChannelCategoryMapping[]

  @@map("sales_channels")
}

model ChannelFee {
  id        String       @id @default(uuid())
  channelId String       @map("channel_id")
  channel   SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  feeType   FeeType      @map("fee_type")
  value     Decimal      @db.Decimal(12, 2)
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("channel_fees")
}

enum FeeType {
  PERCENTAGE
  FIXED
}

// ============================================================
// 거래처 (공급자) 관리
// ============================================================

enum PaymentMethod {
  CREDIT
  PREPAID
}

model Supplier {
  id              String        @id @default(uuid())
  name            String
  businessNumber  String?       @map("business_number")
  representative  String?
  phone           String?
  fax             String?
  email           String?
  address         String?
  bankName        String?       @map("bank_name")
  bankAccount     String?       @map("bank_account")
  bankHolder      String?       @map("bank_holder")
  paymentMethod   PaymentMethod @default(CREDIT) @map("payment_method")
  paymentTermDays Int           @default(30) @map("payment_term_days")
  memo            String?
  isActive        Boolean       @default(true) @map("is_active")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  supplierProducts SupplierProduct[]
  incomings        Incoming[]
  payments         SupplierPayment[]
  balanceLedger    SupplierLedger[]
  contacts         SupplierContact[]
  supplierReturns  SupplierReturn[]
  quotations       Quotation[]
  expenses         Expense[]

  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  phone      String?
  email      String?
  position   String?
  memo       String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("supplier_contacts")
}

model SupplierLedger {
  id            String          @id @default(uuid())
  supplierId    String          @map("supplier_id")
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  date          DateTime        @default(now())
  type          LedgerEntryType
  description   String
  debitAmount   Decimal         @default(0) @map("debit_amount") @db.Decimal(15, 2)
  creditAmount  Decimal         @default(0) @map("credit_amount") @db.Decimal(15, 2)
  balance       Decimal         @map("balance") @db.Decimal(15, 2)
  referenceId   String?         @map("reference_id")
  referenceType String?         @map("reference_type")
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([supplierId, date])
  @@map("supplier_ledgers")
}

enum LedgerEntryType {
  PURCHASE
  PAYMENT
  ADJUSTMENT
  REFUND
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String   @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @map("payment_date")
  method      String
  memo        String?
  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([supplierId, paymentDate])
  @@map("supplier_payments")
}

// ============================================================
// 상품 관리
// ============================================================

enum TaxType {
  TAXABLE
  TAX_FREE
  ZERO_RATE
}

enum ProductType {
  FINISHED // 완제품
  PARTS // 부속
  SET // 세트상품
  ASSEMBLED // 조립상품
}

model Product {
  id                 String        @id @default(uuid())
  name               String
  brand              String?
  brandId            String?       @map("brand_id")
  brandRef           Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  modelName          String?       @map("model_name")
  spec               String?
  sku                String        @unique
  barcode            String?       @unique
  description        String?
  unitOfMeasure      String        @default("EA") @map("unit_of_measure")
  productType        ProductType   @default(FINISHED) @map("product_type")
  taxType            TaxType       @default(TAXABLE) @map("tax_type")
  taxRate            Decimal       @default(0.1) @map("tax_rate") @db.Decimal(5, 4)
  listPrice          Decimal       @default(0) @map("list_price") @db.Decimal(15, 2)
  sellingPrice       Decimal       @default(0) @map("selling_price") @db.Decimal(15, 2)
  isSet              Boolean       @default(false) @map("is_set")
  isCanonical        Boolean       @default(false) @map("is_canonical")
  canonicalProductId String?       @map("canonical_product_id")
  canonicalProduct   Product?      @relation("ProductVariants", fields: [canonicalProductId], references: [id], onDelete: SetNull)
  variants           Product[]     @relation("ProductVariants")
  categoryId         String?       @map("category_id")
  category           ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isBulk             Boolean       @default(false) @map("is_bulk")
  containerSize      Decimal?      @map("container_size") @db.Decimal(10, 4)
  bulkProductId      String?       @map("bulk_product_id")
  bulkProduct        Product?      @relation("ProductBulk", fields: [bulkProductId], references: [id], onDelete: SetNull)
  salesContainers    Product[]     @relation("ProductBulk")
  isActive           Boolean       @default(true) @map("is_active")
  imageUrl           String?       @map("image_url")
  memo               String?
  assemblyTemplateId String?       @map("assembly_template_id")
  assemblyTemplate   AssemblyTemplate? @relation("ProductDefaultTemplate", fields: [assemblyTemplateId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  setComponents      SetComponent[]      @relation("SetParent")
  partOfSets         SetComponent[]      @relation("SetChild")
  productMappings    ProductMapping[]
  channelPricings    ChannelPricing[]
  repairPackageParts RepairPackagePart[]
  inventory          Inventory?
  orderItems         OrderItem[]
  sellingCosts       SellingCost[]
  quotationItems     QuotationItem[]
  statementItems     StatementItem[]
  inventoryLots      InventoryLot[]
  media              ProductMedia[]
  customerMachines   CustomerMachine[]
  repairParts        RepairPart[]
  rentalAssets       RentalAsset[]

  assemblies                    Assembly[]
  assemblyComponentConsumptions AssemblyComponentConsumption[]
  assemblyTemplateSlotDefaults  AssemblyTemplateSlot[]
  assemblyPresetItems           AssemblyPresetItem[]

  specValues ProductSpecValue[]

  @@map("products")
}

enum ProductSpecType {
  TEXT
  NUMBER
  ENUM
}

model ProductSpecSlot {
  id        String          @id @default(uuid())
  name      String          @unique
  type      ProductSpecType
  unit      String?
  options   String[]        @default([])
  order     Int             @default(0)
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  values ProductSpecValue[]

  @@map("product_spec_slots")
}

model ProductSpecValue {
  id        String          @id @default(uuid())
  productId String          @map("product_id")
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  slotId    String          @map("slot_id")
  slot      ProductSpecSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)
  value     String
  order     Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([productId, slotId])
  @@index([productId])
  @@map("product_spec_values")
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  logoUrl   String?   @map("logo_url")
  logoPath  String?   @map("logo_path")
  memo      String?
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("brands")
}

model ProductCategory {
  id        String            @id @default(uuid())
  name      String
  parentId  String?           @map("parent_id")
  parent    ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ProductCategory[] @relation("CategoryTree")
  imageUrl  String?           @map("image_url")
  imagePath String?           @map("image_path")
  order     Int               @default(0)
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  products        Product[]
  channelMappings ChannelCategoryMapping[]

  @@map("product_categories")
}

model ChannelCategoryMapping {
  id                  String          @id @default(uuid())
  categoryId          String          @map("category_id")
  category            ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  channelId           String          @map("channel_id")
  channel             SalesChannel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelCategoryCode String          @map("channel_category_code")
  channelCategoryName String?         @map("channel_category_name")

  @@unique([categoryId, channelId])
  @@map("channel_category_mappings")
}

enum SupplierProductSource {
  MANUAL
  INITIAL
  INCOMING
}

model SupplierProduct {
  id            String                @id @default(uuid())
  supplierId    String                @map("supplier_id")
  supplier      Supplier              @relation(fields: [supplierId], references: [id])
  name          String
  spec          String?
  supplierCode  String?               @map("supplier_code")
  unitOfMeasure String                @default("EA") @map("unit_of_measure")
  listPrice     Decimal               @default(0) @map("list_price") @db.Decimal(15, 2)
  unitPrice     Decimal               @default(0) @map("unit_price") @db.Decimal(15, 2)
  isTaxable     Boolean               @default(true) @map("is_taxable")
  currency      String                @default("KRW")
  leadTimeDays  Int?                  @map("lead_time_days")
  minOrderQty   Int                   @default(1) @map("min_order_qty")
  source        SupplierProductSource @default(MANUAL)
  isProvisional Boolean               @default(false) @map("is_provisional")
  isActive      Boolean               @default(true) @map("is_active")
  memo          String?
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  productMappings ProductMapping[]
  incomingItems   IncomingItem[]
  incomingCosts   IncomingCost[]
  priceHistory    SupplierProductPriceHistory[]
  returnItems     SupplierReturnItem[]
  quotationItems  QuotationItem[]
  inventoryLots   InventoryLot[]

  @@unique([supplierId, supplierCode])
  @@map("supplier_products")
}

model SupplierProductPriceHistory {
  id                String          @id @default(uuid())
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  oldPrice          Decimal         @map("old_price") @db.Decimal(15, 2)
  newPrice          Decimal         @map("new_price") @db.Decimal(15, 2)
  changeAmount      Decimal         @map("change_amount") @db.Decimal(15, 2)
  changePercent     Decimal         @map("change_percent") @db.Decimal(8, 2)
  originalPrice     Decimal?        @map("original_price") @db.Decimal(15, 2)
  discountAmount    Decimal?        @map("discount_amount") @db.Decimal(15, 2)
  reason            String?
  incomingId        String?         @map("incoming_id")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@map("supplier_product_price_history")
}

model ProductMapping {
  id                String          @id @default(uuid())
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  productId         String          @map("product_id")
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  conversionRate    Decimal         @default(1) @map("conversion_rate") @db.Decimal(10, 4)
  createdAt         DateTime        @default(now()) @map("created_at")

  @@unique([supplierProductId, productId])
  @@map("product_mappings")
}

model SetComponent {
  id           String   @id @default(uuid())
  setProductId String   @map("set_product_id")
  setProduct   Product  @relation("SetParent", fields: [setProductId], references: [id], onDelete: Cascade)
  componentId  String   @map("component_id")
  component    Product  @relation("SetChild", fields: [componentId], references: [id], onDelete: Restrict)
  quantity     Decimal  @db.Decimal(10, 4)
  label        String?
  slotLabelId  String?            @map("slot_label_id")
  slotLabel    AssemblySlotLabel? @relation(fields: [slotLabelId], references: [id], onDelete: SetNull)
  slotId       String?               @map("slot_id")
  slot         AssemblyTemplateSlot? @relation(fields: [slotId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([setProductId, componentId])
  @@index([slotLabelId])
  @@index([slotId])
  @@map("set_components")
}

model ChannelPricing {
  id           String       @id @default(uuid())
  productId    String       @map("product_id")
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelId    String       @map("channel_id")
  channel      SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sellingPrice Decimal      @map("selling_price") @db.Decimal(15, 2)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@unique([productId, channelId])
  @@map("channel_pricings")
}

// ============================================================
// 비용 관리
// ============================================================

model IncomingCost {
  id                String          @id @default(uuid())
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  name              String
  costType          FeeType         @map("cost_type")
  value             Decimal         @db.Decimal(12, 2)
  perUnit           Boolean         @default(true) @map("per_unit")
  isTaxable         Boolean         @default(true) @map("is_taxable")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at")

  @@map("incoming_costs")
}

model SellingCost {
  id        String        @id @default(uuid())
  productId String        @map("product_id")
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelId String?       @map("channel_id")
  channel   SalesChannel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  name      String
  costType  FeeType       @map("cost_type")
  value     Decimal       @db.Decimal(12, 2)
  perUnit   Boolean       @default(true) @map("per_unit")
  isTaxable Boolean       @default(true) @map("is_taxable")
  isActive  Boolean       @default(true) @map("is_active")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([productId, channelId])
  @@map("selling_costs")
}

// ============================================================
// 재고 관리
// ============================================================

model Inventory {
  id               String    @id @default(uuid())
  productId        String    @unique @map("product_id")
  product          Product   @relation(fields: [productId], references: [id])
  quantity         Decimal   @default(0) @db.Decimal(15, 4)
  safetyStock      Decimal   @default(1) @map("safety_stock") @db.Decimal(15, 4)
  avgCost          Decimal?  @map("avg_cost") @db.Decimal(15, 4)
  avgCostUpdatedAt DateTime? @map("avg_cost_updated_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  movements InventoryMovement[]

  @@map("inventories")
}

enum MovementType {
  INCOMING
  OUTGOING
  ADJUSTMENT_PLUS
  ADJUSTMENT_MINUS
  SET_CONSUME
  SET_PRODUCE
  RETURN
  INITIAL
  STOCKTAKE_PLUS
  STOCKTAKE_MINUS
  INTERNAL_USE
  BOTTLE_OPEN_OUT
  BOTTLE_OPEN_IN
}

enum InventoryUsageReason {
  SAMPLE
  SELF_USE
  DAMAGE
  LOSS
  SUPPLIES
}

enum StocktakeReason {
  PHYSICAL_COUNT
  DAMAGE
  LOSS
  FOUND
  SAMPLE
  MISCOUNT
  OTHER
}

model InventoryMovement {
  id            String                @id @default(uuid())
  inventoryId   String                @map("inventory_id")
  inventory     Inventory             @relation(fields: [inventoryId], references: [id])
  type          MovementType
  quantity      Decimal               @db.Decimal(15, 4)
  balanceAfter  Decimal               @map("balance_after") @db.Decimal(15, 4)
  reason        StocktakeReason?
  usageReason   InventoryUsageReason? @map("usage_reason")
  referenceId   String?               @map("reference_id")
  referenceType String?               @map("reference_type")
  memo          String?
  createdAt     DateTime              @default(now()) @map("created_at")

  @@index([inventoryId, createdAt])
  @@map("inventory_movements")
}

// ============================================================
// 입고 관리
// ============================================================

enum IncomingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Incoming {
  id                String         @id @default(uuid())
  incomingNo        String         @unique @map("incoming_no")
  supplierId        String         @map("supplier_id")
  supplier          Supplier       @relation(fields: [supplierId], references: [id])
  status            IncomingStatus @default(PENDING)
  incomingDate      DateTime       @map("incoming_date")
  totalAmount       Decimal        @default(0) @map("total_amount") @db.Decimal(15, 2)
  taxAmount         Decimal        @default(0) @map("tax_amount") @db.Decimal(15, 2)
  shippingCost      Decimal        @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  shippingIsTaxable Boolean        @default(true) @map("shipping_is_taxable")
  shippingDeducted  Boolean        @default(false) @map("shipping_deducted")
  memo              String?
  quotationId       String?        @map("quotation_id")
  quotation         Quotation?     @relation(fields: [quotationId], references: [id])
  createdById       String         @map("created_by_id")
  createdBy         User           @relation(fields: [createdById], references: [id])
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  items          IncomingItem[]
  supplierReturn SupplierReturn?

  @@index([supplierId, incomingDate])
  @@map("incomings")
}

model IncomingItem {
  id                String          @id @default(uuid())
  incomingId        String          @map("incoming_id")
  incoming          Incoming        @relation(fields: [incomingId], references: [id], onDelete: Cascade)
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id])
  inventoryLots     InventoryLot[]
  quantity          Decimal         @db.Decimal(15, 4)
  originalPrice     Decimal?        @map("original_price") @db.Decimal(15, 2)
  discountAmount    Decimal?        @map("discount_amount") @db.Decimal(15, 2)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(15, 2)
  totalPrice        Decimal         @map("total_price") @db.Decimal(15, 2)
  unitCostSnapshot  Decimal?        @map("unit_cost_snapshot") @db.Decimal(15, 4)
  itemShippingCost      Decimal?    @map("item_shipping_cost") @db.Decimal(12, 2)
  itemShippingIsTaxable Boolean     @default(true) @map("item_shipping_is_taxable")
  memo              String?

  @@map("incoming_items")
}

// ============================================================
// 주문 관리
// ============================================================

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

model Order {
  id                  String              @id @default(uuid())
  orderNo             String              @unique @map("order_no")
  channelId           String?             @map("channel_id")
  channel             SalesChannel?       @relation(fields: [channelId], references: [id])
  channelOrderNo      String?             @map("channel_order_no")
  status              OrderStatus         @default(PENDING)
  customerId          String?             @map("customer_id")
  customer            Customer?           @relation(fields: [customerId], references: [id])
  customerName        String?             @map("customer_name")
  customerPhone       String?             @map("customer_phone")
  shippingAddress     String?             @map("shipping_address")
  orderDate           DateTime            @map("order_date")
  quotationId         String?             @map("quotation_id")
  quotation           Quotation?          @relation(fields: [quotationId], references: [id])
  subtotalAmount      Decimal             @default(0) @map("subtotal_amount") @db.Decimal(15, 2)
  discountAmount      Decimal             @default(0) @map("discount_amount") @db.Decimal(15, 2)
  shippingFee         Decimal             @default(0) @map("shipping_fee") @db.Decimal(15, 2)
  taxAmount           Decimal             @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount         Decimal             @default(0) @map("total_amount") @db.Decimal(15, 2)
  commissionAmount    Decimal             @default(0) @map("commission_amount") @db.Decimal(15, 2)
  paymentMethod       OrderPaymentMethod? @map("payment_method")
  taxInvoiceRequested Boolean             @default(false) @map("tax_invoice_requested")
  taxInvoicedAt       DateTime?           @map("tax_invoiced_at")
  memo                String?
  repairTicketId      String?             @map("repair_ticket_id")
  repairTicket        RepairTicket?       @relation(fields: [repairTicketId], references: [id])
  rentalId            String?             @map("rental_id")
  rental              Rental?             @relation(fields: [rentalId], references: [id])
  createdById         String              @map("created_by_id")
  createdBy           User                @relation(fields: [createdById], references: [id])
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  items      OrderItem[]
  statements Statement[]

  @@index([channelId, orderDate])
  @@index([status])
  @@index([repairTicketId])
  @@index([rentalId])
  @@map("orders")
}

model OrderItem {
  id                            String   @id @default(uuid())
  orderId                       String   @map("order_id")
  order                         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId                     String?  @map("product_id")
  product                       Product? @relation(fields: [productId], references: [id])
  canonicalProductId            String?  @map("canonical_product_id")
  serviceName                   String?  @map("service_name")
  quantity                      Decimal  @db.Decimal(15, 4)
  unitPrice                     Decimal  @map("unit_price") @db.Decimal(15, 2)
  totalPrice                    Decimal  @map("total_price") @db.Decimal(15, 2)
  unitCostSnapshot              Decimal? @map("unit_cost_snapshot") @db.Decimal(15, 4)
  channelCommissionRateSnapshot Decimal? @map("channel_commission_rate_snapshot") @db.Decimal(5, 4)
  cardFeeRateSnapshot           Decimal? @map("card_fee_rate_snapshot") @db.Decimal(5, 4)
  sellingCostSnapshot           Decimal? @map("selling_cost_snapshot") @db.Decimal(15, 4)
  memo                          String?

  lotConsumptions LotConsumption[]

  @@map("order_items")
}

// ============================================================
// 로트 기반 재고 추적 (FIFO)
// ============================================================

enum LotSource {
  INCOMING
  INITIAL
  ADJUSTMENT
  SET_PRODUCE
}

model InventoryLot {
  id                String           @id @default(uuid())
  productId         String?          @map("product_id")
  product           Product?         @relation(fields: [productId], references: [id])
  supplierProductId String?          @map("supplier_product_id")
  supplierProduct   SupplierProduct? @relation(fields: [supplierProductId], references: [id])
  receivedQty       Decimal          @map("received_qty") @db.Decimal(15, 4)
  remainingQty      Decimal          @map("remaining_qty") @db.Decimal(15, 4)
  unitCost          Decimal          @map("unit_cost") @db.Decimal(15, 4)
  originalPrice     Decimal?         @map("original_price") @db.Decimal(15, 4)
  discountAmount    Decimal?         @map("discount_amount") @db.Decimal(15, 4)
  receivedAt        DateTime         @map("received_at")
  source            LotSource
  incomingItemId    String?          @map("incoming_item_id")
  incomingItem      IncomingItem?    @relation(fields: [incomingItemId], references: [id])
  memo              String?
  createdAt         DateTime         @default(now()) @map("created_at")

  consumptions LotConsumption[]

  @@index([productId, receivedAt])
  @@index([supplierProductId, receivedAt])
  @@index([incomingItemId])
  @@map("inventory_lots")
}

model LotConsumption {
  id           String       @id @default(uuid())
  orderItemId  String?      @map("order_item_id")
  orderItem    OrderItem?   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  repairPartId String?      @map("repair_part_id")
  repairPart   RepairPart?  @relation(fields: [repairPartId], references: [id], onDelete: Cascade)
  lotId        String       @map("lot_id")
  lot          InventoryLot @relation(fields: [lotId], references: [id])
  quantity     Decimal      @db.Decimal(15, 4)
  unitCost     Decimal      @map("unit_cost") @db.Decimal(15, 4)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([orderItemId])
  @@index([repairPartId])
  @@index([lotId])
  @@map("lot_consumptions")
}

// ============================================================
// 반품 관리
// ============================================================

enum ReturnStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model SupplierReturn {
  id                 String       @id @default(uuid())
  returnNo           String       @unique @map("return_no")
  supplierId         String       @map("supplier_id")
  supplier           Supplier     @relation(fields: [supplierId], references: [id])
  status             ReturnStatus @default(PENDING)
  returnDate         DateTime     @map("return_date")
  returnReason        String?      @map("return_reason")
  memo                String?
  returnCost          Decimal?     @map("return_cost") @db.Decimal(12, 2)
  returnCostIsTaxable Boolean      @default(true) @map("return_cost_is_taxable")
  returnCostType      String?      @map("return_cost_type") // ADD | DEDUCT | SEPARATE
  returnCostNote      String?      @map("return_cost_note")
  exchangeIncomingId  String?      @unique @map("exchange_incoming_id")
  exchangeIncoming   Incoming?    @relation(fields: [exchangeIncomingId], references: [id])
  createdById        String       @map("created_by_id")
  createdBy          User         @relation(fields: [createdById], references: [id])
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  items SupplierReturnItem[]

  @@index([supplierId, returnDate])
  @@map("supplier_returns")
}

model SupplierReturnItem {
  id                String          @id @default(uuid())
  returnId          String          @map("return_id")
  return            SupplierReturn  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  supplierProductId String          @map("supplier_product_id")
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id])
  quantity          Decimal         @db.Decimal(15, 4)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(15, 2)
  totalPrice        Decimal         @map("total_price") @db.Decimal(15, 2)
  memo              String?

  @@map("supplier_return_items")
}

// ============================================================
// 카드수수료율
// ============================================================

model CardFeeRate {
  id          String   @id @default(uuid())
  rate        Decimal  @db.Decimal(5, 4)
  memo        String?
  appliedFrom DateTime @map("applied_from")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("card_fee_rates")
}

// ============================================================
// 가맹점 카드사별 수수료 정보 (참고용 + 평균 산출 소스)
// ============================================================

model CardMerchantInfo {
  id           String    @id @default("singleton")
  merchantTier String?   @map("merchant_tier")
  appliedFrom  DateTime? @map("applied_from")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("card_merchant_info")
}

model CardCompanyFee {
  id                String   @id @default(uuid())
  companyName       String   @map("company_name")
  merchantNo        String?  @map("merchant_no")
  settlementBank    String?  @map("settlement_bank")
  settlementAccount String?  @map("settlement_account")
  creditRate        Decimal  @map("credit_rate") @db.Decimal(5, 4)
