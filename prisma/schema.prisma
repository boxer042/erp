// ============================================================
// 우리 사업자 정보 / 통장
// ============================================================

model CompanyInfo {
  id             String   @id @default("singleton")
  name           String
  businessNumber String?  @map("business_number")
  ceo            String?
  phone          String?
  email          String?
  address        String?
  businessType   String?  @map("business_type")
  businessItem   String?  @map("business_item")
  updatedAt      DateTime @updatedAt @map("updated_at")

  bankAccounts CompanyBankAccount[]

  @@map("company_info")
}

model CompanyBankAccount {
  id        String   @id @default(uuid())
  companyId String   @default("singleton") @map("company_id")
  bankName  String   @map("bank_name")
  holder    String
  account   String
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  company CompanyInfo @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, sortOrder])
  @@map("company_bank_accounts")
}

// ============================================================
// 고객 (Customer) — 판매 상대방
// ============================================================

model Customer {
  id             String   @id @default(uuid())
  name           String
  phone          String
  businessNumber String?  @map("business_number")
  ceo            String?
  email          String?
  address        String?
  memo           String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  quotations Quotation[]
  statements Statement[]
  orders     Order[]
  ledger     CustomerLedger[]
  payments   CustomerPayment[]
  machines   CustomerMachine[]
  notes      CustomerNote[]
  repairs    RepairTicket[]
  rentals    Rental[]
  expenses   Expense[]

  @@index([name])
  @@index([phone])
  @@map("customers")
}

enum CustomerLedgerType {
  SALE // 매출 (미수금 증가)
  RECEIPT // 수금 (미수금 감소)
  ADJUSTMENT
  REFUND // 환불 (미수금 증가)
}

model CustomerLedger {
  id            String             @id @default(uuid())
  customerId    String             @map("customer_id")
  customer      Customer           @relation(fields: [customerId], references: [id])
  date          DateTime           @default(now())
  type          CustomerLedgerType
  description   String
  debitAmount   Decimal            @default(0) @map("debit_amount") @db.Decimal(15, 2) // 매출/환불(증가)
  creditAmount  Decimal            @default(0) @map("credit_amount") @db.Decimal(15, 2) // 수금(감소)
  balance       Decimal            @map("balance") @db.Decimal(15, 2)
  referenceId   String?            @map("reference_id")
  referenceType String?            @map("reference_type")
  createdAt     DateTime           @default(now()) @map("created_at")

  @@index([customerId, date])
  @@map("customer_ledgers")
}

model CustomerPayment {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id])
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime @map("payment_date")
  method      String
  memo        String?
  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([customerId, paymentDate])
  @@map("customer_payments")
}

// ============================================================
// 견적서 (Quotation) — 판매/매입 통합
// ============================================================

enum QuotationType {
  SALES
  PURCHASE
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quotation {
  id             String          @id @default(uuid())
  quotationNo    String          @unique @map("quotation_no")
  type           QuotationType
  status         QuotationStatus @default(DRAFT)
  issueDate      DateTime        @map("issue_date")
  validUntil     DateTime?       @map("valid_until")
  customerId     String?         @map("customer_id")
  customer       Customer?       @relation(fields: [customerId], references: [id])
  supplierId     String?         @map("supplier_id")
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  title          String?
  subtotalAmount Decimal         @default(0) @map("subtotal_amount") @db.Decimal(15, 2)
  taxAmount      Decimal         @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount    Decimal         @default(0) @map("total_amount") @db.Decimal(15, 2)
  memo           String?
  terms          String?
  createdById    String          @map("created_by_id")
  createdBy      User            @relation(fields: [createdById], references: [id])
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  items      QuotationItem[]
  orders     Order[]
  incomings  Incoming[]
  statements Statement[]

  @@index([type, issueDate])
  @@index([status])
  @@map("quotations")
}

model QuotationItem {
  id                String           @id @default(uuid())
  quotationId       String           @map("quotation_id")
  quotation         Quotation        @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId         String?          @map("product_id")
  product           Product?         @relation(fields: [productId], references: [id])
  supplierProductId String?          @map("supplier_product_id")
  supplierProduct   SupplierProduct? @relation(fields: [supplierProductId], references: [id])
  name              String
  spec              String?
  unitOfMeasure     String           @default("EA") @map("unit_of_measure")
  quantity          Decimal          @db.Decimal(15, 4)
  listPrice         Decimal          @default(0) @map("list_price") @db.Decimal(15, 2)
  discountAmount    Decimal          @default(0) @map("discount_amount") @db.Decimal(15, 2)
  unitPrice         Decimal          @map("unit_price") @db.Decimal(15, 2)
  totalPrice        Decimal          @map("total_price") @db.Decimal(15, 2)
  isTaxable         Boolean          @default(true) @map("is_taxable")
  sortOrder         Int              @default(0) @map("sort_order")
  memo              String?

  @@map("quotation_items")
}

// ============================================================
// 거래명세표 (Statement) — 판매용
// ============================================================

enum StatementStatus {
  DRAFT
  ISSUED
  CANCELLED
}

model Statement {
  id                             String          @id @default(uuid())
  statementNo                    String          @unique @map("statement_no")
  status                         StatementStatus @default(ISSUED)
  issueDate                      DateTime        @map("issue_date")
  customerId                     String?         @map("customer_id")
  customer                       Customer?       @relation(fields: [customerId], references: [id])
  customerNameSnapshot           String?         @map("customer_name_snapshot")
  customerPhoneSnapshot          String?         @map("customer_phone_snapshot")
  customerAddressSnapshot        String?         @map("customer_address_snapshot")
  customerBusinessNumberSnapshot String?         @map("customer_business_number_snapshot")
  orderId                        String?         @map("order_id")
  order                          Order?          @relation(fields: [orderId], references: [id])
  quotationId                    String?         @map("quotation_id")
  quotation                      Quotation?      @relation(fields: [quotationId], references: [id])
  subtotalAmount                 Decimal         @default(0) @map("subtotal_amount") @db.Decimal(15, 2)
  taxAmount                      Decimal         @default(0) @map("tax_amount") @db.Decimal(15, 2)
  totalAmount                    Decimal         @default(0) @map("total_amount") @db.Decimal(15, 2)
  memo                           String?
  createdById                    String          @map("created_by_id")
  createdBy                      User            @relation(fields: [createdById], references: [id])
  createdAt                      DateTime        @default(now()) @map("created_at")
  updatedAt                      DateTime        @updatedAt @map("updated_at")

  items StatementItem[]

  @@index([issueDate])
  @@map("statements")
}

model StatementItem {
  id             String    @id @default(uuid())
  statementId    String    @map("statement_id")
  statement      Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  productId      String?   @map("product_id")
  product        Product?  @relation(fields: [productId], references: [id])
  name           String
  spec           String?
  unitOfMeasure  String    @default("EA") @map("unit_of_measure")
  quantity       Decimal   @db.Decimal(15, 4)
  listPrice      Decimal   @default(0) @map("list_price") @db.Decimal(15, 2)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 2)
  unitPrice      Decimal   @map("unit_price") @db.Decimal(15, 2)
  totalPrice     Decimal   @map("total_price") @db.Decimal(15, 2)
  isTaxable      Boolean   @default(true) @map("is_taxable")
  sortOrder      Int       @default(0) @map("sort_order")
  memo           String?

  @@map("statement_items")
}

// ============================================================
// POS — 상품 미디어, 결제수단, 고객 보유 기계, 방문 메모
// ============================================================

enum ProductMediaType {
  IMAGE
  YOUTUBE
}

model ProductMedia {
  id        String           @id @default(uuid())
  productId String           @map("product_id")
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ProductMediaType
  url       String
  title     String?
  sortOrder Int              @default(0) @map("sort_order")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([productId, sortOrder])
  @@map("product_media")
}

enum OrderPaymentMethod {
  CASH
  CARD
  TRANSFER
  MIXED
  UNPAID
}

model CustomerMachine {
  id            String    @id @default(uuid())
  customerId    String    @map("customer_id")
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId     String?   @map("product_id")
  product       Product?  @relation(fields: [productId], references: [id])
  name          String
  brand         String?
  modelNo       String?   @map("model_no")
  serialNo      String?   @map("serial_no")
  purchasedAt   DateTime? @map("purchased_at")
  purchasedFrom String?   @map("purchased_from")
  memo          String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  repairs RepairTicket[]

  @@index([customerId])
  @@map("customer_machines")
}

model CustomerNote {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content     String
  createdById String   @map("created_by_id")
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([customerId, createdAt])
  @@map("customer_notes")
}

// ============================================================
// 수리 (RepairTicket)
// ============================================================

enum RepairStatus {
  RECEIVED
  DIAGNOSING
  QUOTED
  APPROVED
  REPAIRING
  READY
  PICKED_UP
  CANCELLED
}

enum RepairApprovalMethod {
  ON_SITE
  REMOTE
}

model RepairTicket {
  id                     String                @id @default(uuid())
  ticketNo               String                @unique @map("ticket_no")
  customerId             String                @map("customer_id")
  customer               Customer              @relation(fields: [customerId], references: [id])
  customerMachineId      String?               @map("customer_machine_id")
  customerMachine        CustomerMachine?      @relation(fields: [customerMachineId], references: [id])
  status                 RepairStatus          @default(RECEIVED)
  receivedAt             DateTime              @map("received_at")
  symptom                String?
  diagnosis              String?
  repairNotes            String?               @map("repair_notes")
  quotedLaborAmount      Decimal               @default(0) @map("quoted_labor_amount") @db.Decimal(15, 2)
  quotedPartsAmount      Decimal               @default(0) @map("quoted_parts_amount") @db.Decimal(15, 2)
  quotedTotalAmount      Decimal               @default(0) @map("quoted_total_amount") @db.Decimal(15, 2)
  quotedAt               DateTime?             @map("quoted_at")
  approvalMethod         RepairApprovalMethod? @map("approval_method")
  approvalToken          String?               @unique @map("approval_token")
  approvalTokenExpiresAt DateTime?             @map("approval_token_expires_at")
  approvedAt             DateTime?             @map("approved_at")
  approvedByName         String?               @map("approved_by_name")
  startedAt              DateTime?             @map("started_at")
  readyAt                DateTime?             @map("ready_at")
  pickedUpAt             DateTime?             @map("picked_up_at")
  finalAmount            Decimal               @default(0) @map("final_amount") @db.Decimal(15, 2)
  paymentMethod          OrderPaymentMethod?   @map("payment_method")
  memo                   String?
  createdById            String                @map("created_by_id")
  createdBy              User                  @relation(fields: [createdById], references: [id])
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")

  parts  RepairPart[]
  labors RepairLabor[]
  orders Order[]

  @@index([customerId])
  @@index([status])
  @@index([receivedAt])
  @@map("repair_tickets")
}

model RepairPart {
  id               String       @id @default(uuid())
  repairTicketId   String       @map("repair_ticket_id")
  repairTicket     RepairTicket @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  productId        String       @map("product_id")
  product          Product      @relation(fields: [productId], references: [id])
  quantity         Decimal      @db.Decimal(15, 4)
  unitPrice        Decimal      @map("unit_price") @db.Decimal(15, 2)
  totalPrice       Decimal      @map("total_price") @db.Decimal(15, 2)
  unitCostSnapshot Decimal?     @map("unit_cost_snapshot") @db.Decimal(15, 4)
  consumedAt       DateTime?    @map("consumed_at")
  createdAt        DateTime     @default(now()) @map("created_at")

  lotConsumptions LotConsumption[]

  @@index([repairTicketId])
  @@map("repair_parts")
}

model RepairLabor {
  id             String       @id @default(uuid())
  repairTicketId String       @map("repair_ticket_id")
  repairTicket   RepairTicket @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  name           String
  hours          Decimal      @default(1) @db.Decimal(10, 2)
  unitRate       Decimal      @map("unit_rate") @db.Decimal(15, 2)
  totalPrice     Decimal      @map("total_price") @db.Decimal(15, 2)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([repairTicketId])
  @@map("repair_labors")
}

// ============================================================
// 수리 서비스 카탈로그 (공임 프리셋 / 수리 패키지)
// ============================================================

model RepairLaborPreset {
  id          String   @id @default(uuid())
  name        String
  description String?
  unitRate    Decimal  @map("unit_rate") @db.Decimal(15, 2)
  isActive    Boolean  @default(true) @map("is_active")
  memo        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  packageLabors RepairPackageLabor[]

  @@map("repair_labor_presets")
}

model RepairPackage {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  memo        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  labors RepairPackageLabor[]
  parts  RepairPackagePart[]

  @@map("repair_packages")
}

model RepairPackageLabor {
  id            String             @id @default(uuid())
  packageId     String             @map("package_id")
  package       RepairPackage      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  laborPresetId String?            @map("labor_preset_id")
  laborPreset   RepairLaborPreset? @relation(fields: [laborPresetId], references: [id])
  name          String
  unitRate      Decimal            @map("unit_rate") @db.Decimal(15, 2)
  quantity      Int                @default(1)
  sortOrder     Int                @default(0) @map("sort_order")

  @@index([packageId])
  @@map("repair_package_labors")
}

model RepairPackagePart {
  id        String        @id @default(uuid())
  packageId String        @map("package_id")
  package   RepairPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  productId String        @map("product_id")
  product   Product       @relation(fields: [productId], references: [id])
  quantity  Decimal       @db.Decimal(15, 4)
  unitPrice Decimal       @map("unit_price") @db.Decimal(15, 2)

  @@index([packageId])
  @@map("repair_package_parts")
}

// ============================================================
// 임대 (RentalAsset / Rental) — 판매 재고와 완전 분리
// ============================================================

enum RentalAssetStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

enum RentalRateType {
  DAILY
  MONTHLY
}

enum RentalStatus {
  RESERVED
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

model RentalAsset {
  id            String            @id @default(uuid())
  assetNo       String            @unique @map("asset_no")
  name          String
  brand         String?
  modelNo       String?           @map("model_no")
  serialNo      String?           @map("serial_no")
  productId     String?           @map("product_id")
  product       Product?          @relation(fields: [productId], references: [id])
  dailyRate     Decimal           @default(0) @map("daily_rate") @db.Decimal(15, 2)
  monthlyRate   Decimal           @default(0) @map("monthly_rate") @db.Decimal(15, 2)
  depositAmount Decimal           @default(0) @map("deposit_amount") @db.Decimal(15, 2)
  status        RentalAssetStatus @default(AVAILABLE)
  acquiredAt    DateTime?         @map("acquired_at")
  memo          String?
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  rentals Rental[]

  @@map("rental_assets")
}

model Rental {
  id               String              @id @default(uuid())
  rentalNo         String              @unique @map("rental_no")
  assetId          String              @map("asset_id")
  asset            RentalAsset         @relation(fields: [assetId], references: [id])
  customerId       String              @map("customer_id")
  customer         Customer            @relation(fields: [customerId], references: [id])
  status           RentalStatus        @default(RESERVED)
  startDate        DateTime            @map("start_date")
  endDate          DateTime            @map("end_date")
  actualReturnedAt DateTime?           @map("actual_returned_at")
  rateType         RentalRateType      @map("rate_type")
  unitRate         Decimal             @map("unit_rate") @db.Decimal(15, 2)
  totalUnits       Int                 @map("total_units")
  rentalAmount     Decimal             @map("rental_amount") @db.Decimal(15, 2)
  depositAmount    Decimal             @default(0) @map("deposit_amount") @db.Decimal(15, 2)
  depositReturned  Boolean             @default(false) @map("deposit_returned")
  overdueAmount    Decimal             @default(0) @map("overdue_amount") @db.Decimal(15, 2)
  finalAmount      Decimal             @default(0) @map("final_amount") @db.Decimal(15, 2)
  paymentMethod    OrderPaymentMethod? @map("payment_method")
  memo             String?
  createdById      String              @map("created_by_id")
  createdBy        User                @relation(fields: [createdById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  orders Order[]

  @@index([customerId])
  @@index([assetId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("rentals")
}

model Expense {
  id             String              @id @default(uuid())
  date           DateTime
  amount         Decimal             @db.Decimal(12, 2)
  category       ExpenseCategory
  description    String
  isTaxable      Boolean             @default(true) @map("is_taxable")
  recoverable    Boolean             @default(false) @map("recoverable")
  paymentMethod  OrderPaymentMethod? @map("payment_method")
  supplierId     String?             @map("supplier_id")
  supplier       Supplier?           @relation(fields: [supplierId], references: [id])
  customerId     String?             @map("customer_id")
  customer       Customer?           @relation(fields: [customerId], references: [id])
  createdById    String?             @map("created_by_id")
  createdBy      User?               @relation(fields: [createdById], references: [id])
  referenceId    String?             @map("reference_id")
  referenceType  String?             @map("reference_type")
  memo           String?
  attachmentUrl  String?             @map("attachment_url")
  attachmentPath String?             @map("attachment_path")
  attachmentName String?             @map("attachment_name")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([date])
  @@index([category])
  @@index([supplierId])
  @@index([customerId])
  @@index([createdById])
  @@map("expenses")
}

enum ExpenseCategory {
  SHIPPING
  RENT
  UTILITIES
  SALARY
  PACKAGING
  OFFICE_SUPPLIES
  MARKETING
  MAINTENANCE
  INVENTORY_USAGE
  OTHER
}

// ============================================================
// 조립상품 템플릿 · 프리셋
// ============================================================

model AssemblyTemplate {
  id               String   @id @default(uuid())
  name             String
  description      String?
  defaultLaborCost Decimal? @map("default_labor_cost") @db.Decimal(15, 2)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  slots          AssemblyTemplateSlot[]
  presets        AssemblyPreset[]
  defaultForProducts Product[] @relation("ProductDefaultTemplate")

  @@map("assembly_templates")
}

model AssemblyTemplateSlot {
  id               String             @id @default(uuid())
  templateId       String             @map("template_id")
  template         AssemblyTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label            String
  slotLabelId      String?            @map("slot_label_id")
  slotLabel        AssemblySlotLabel? @relation(fields: [slotLabelId], references: [id], onDelete: Restrict)
  order            Int
  defaultProductId String?            @map("default_product_id")
  defaultProduct   Product?           @relation(fields: [defaultProductId], references: [id], onDelete: SetNull)
  defaultQuantity  Decimal            @default(1) @map("default_quantity") @db.Decimal(10, 4)
  isVariable       Boolean            @default(false) @map("is_variable")

  presetItems   AssemblyPresetItem[]
  setComponents SetComponent[]

  @@index([templateId, order])
  @@index([slotLabelId])
  @@map("assembly_template_slots")
}

model AssemblySlotLabel {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  slots         AssemblyTemplateSlot[]
  setComponents SetComponent[]

  @@map("assembly_slot_labels")
}

model AssemblyPreset {
  id          String           @id @default(uuid())
  templateId  String           @map("template_id")
  template    AssemblyTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  items AssemblyPresetItem[]

  @@unique([templateId, name])
  @@map("assembly_presets")
}

model AssemblyPresetItem {
  id        String               @id @default(uuid())
  presetId  String               @map("preset_id")
  preset    AssemblyPreset       @relation(fields: [presetId], references: [id], onDelete: Cascade)
  slotId    String               @map("slot_id")
  slot      AssemblyTemplateSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  productId String               @map("product_id")
  product   Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Decimal              @db.Decimal(10, 4)

  @@unique([presetId, slotId])
  @@map("assembly_preset_items")
}

// ============================================================
// 조립 실적 (Assembly / Disassembly)
// ============================================================

enum AssemblyType {
  PRODUCE
  DISASSEMBLE
}

model Assembly {
  id            String       @id @default(uuid())
  assemblyNo    String       @unique @map("assembly_no")
  productId     String       @map("product_id")
  product       Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity      Decimal      @db.Decimal(10, 4)
  type          AssemblyType @default(PRODUCE)
  laborCost     Decimal?     @map("labor_cost") @db.Decimal(15, 2)
  assembledAt   DateTime     @map("assembled_at")
  memo          String?
  producedLotId String?      @map("produced_lot_id")
  reverseOfId   String?      @unique @map("reverse_of_id")
  reverseOf     Assembly?    @relation("AssemblyReverse", fields: [reverseOfId], references: [id])
  reversedBy    Assembly?    @relation("AssemblyReverse")
  createdBy     String?      @map("created_by")
  createdAt     DateTime     @default(now()) @map("created_at")

  consumptions AssemblyComponentConsumption[]

  @@index([productId, assembledAt])
  @@map("assemblies")
}

model AssemblyComponentConsumption {
  id          String   @id @default(uuid())
  assemblyId  String   @map("assembly_id")
  assembly    Assembly @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  componentId String   @map("component_id")
  component   Product  @relation(fields: [componentId], references: [id], onDelete: Restrict)
  lotId       String   @map("lot_id")
  quantity    Decimal  @db.Decimal(10, 4)
  unitCost    Decimal  @map("unit_cost") @db.Decimal(15, 4)

  @@index([assemblyId])
  @@index([lotId])
  @@map("assembly_component_consumptions")
}
